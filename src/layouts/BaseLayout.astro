---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Lightbox from '../components/ui/Lightbox.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const defaultDescription = 'Capitole du Libre — L\'événement du Logiciel Libre en Occitanie. 14 & 15 novembre 2026 à l\'ENSEEIHT, Toulouse. Gratuit sur inscription.';

const {
  title,
  description = defaultDescription,
  ogImage = '/static/img/img01.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const fullTitle = `${title} — Capitole du Libre`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <!-- Anti-flash: apply dark class before render -->
    <script is:inline>
      (function() {
        var s = localStorage.getItem('cdl-theme');
        var dark = s === 'dark' || (s !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#d03d00" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Capitole du Libre" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@capitoledulibre" />

    <!-- JSON-LD -->
    <slot name="head" />

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-cdl-bg text-cdl-gray font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-cdl-orange focus:text-white focus:rounded-md"
    >
      Aller au contenu principal
    </a>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
    <Lightbox />
  </body>
</html>

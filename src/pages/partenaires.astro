---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import JsonLd from '../components/ui/JsonLd.astro';
import Picture from '../components/ui/Picture.astro';
import { getPhotosByTag } from '../lib/photos';
import { getCollection } from 'astro:content';
import { config } from '../config';
import { breadcrumb } from '../lib/jsonld';

const sponsorPhotos = getPhotosByTag('sponsor');

const allPartners = await getCollection('partners');

// Sponsors (niveaux classiques)
const sponsorLevels = [
  { key: 'platine', label: 'Platine', logoSize: 'max-h-20', cols: 'sm:grid-cols-2 lg:grid-cols-3' },
  { key: 'or', label: 'Or', logoSize: 'max-h-16', cols: 'sm:grid-cols-3 lg:grid-cols-4' },
  { key: 'argent', label: 'Argent', logoSize: 'max-h-14', cols: 'sm:grid-cols-3 lg:grid-cols-4' },
  { key: 'bronze', label: 'Bronze', logoSize: 'max-h-12', cols: 'sm:grid-cols-4 lg:grid-cols-5' },
] as const;

const sponsors = sponsorLevels
  .map((level) => ({
    ...level,
    partners: allPartners.filter((p) => p.data.level === level.key),
  }))
  .filter((level) => level.partners.length > 0);

// Partenaires techniques
const techPartners = allPartners.filter((p) => p.data.level === 'technique' || p.data.level === 'institutionnel');

const hasAnyPartner = sponsors.length > 0 || techPartners.length > 0;
---

<BaseLayout title="Partenaires" description="Les partenaires et sponsors du Capitole du Libre rendent l'événement possible. Découvrez-les et rejoignez-les !">
  <JsonLd slot="head" data={breadcrumb([{ name: 'Partenaires', path: '/partenaires' }])} />
  <PageHeader title="Partenaires" description="Ils rendent le Capitole du Libre possible." />

  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {hasAnyPartner ? (
        <>
          {/* ── Sponsors ── */}
          {sponsors.length > 0 && (
            <div class="mb-20">
              <div class="text-center mb-10">
                <h2 class="text-2xl sm:text-3xl font-bold text-cdl-blue mb-3">Sponsors</h2>
                <p class="text-cdl-gray max-w-2xl mx-auto">
                  Ils soutiennent financièrement le Capitole du Libre et rendent l'événement gratuit pour tous.
                </p>
              </div>
              <div class="space-y-12">
                {sponsors.map((level) => (
                  <div>
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-cdl-orange mb-6 text-center">{level.label}</h3>
                    <div class:list={['grid grid-cols-2 gap-6', level.cols]}>
                      {level.partners.map((partner) => (
                        <a
                          href={partner.data.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex items-center justify-center p-6 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-md transition-all"
                        >
                          <img
                            src={partner.data.logo_light ?? partner.data.logo}
                            alt={partner.data.name}
                            class:list={['w-auto object-contain dark:hidden', level.logoSize]}
                            loading="lazy"
                          />
                          <img
                            src={partner.data.logo}
                            alt={partner.data.name}
                            class:list={['w-auto object-contain hidden dark:block', level.logoSize]}
                            loading="lazy"
                          />
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* ── Partenaires techniques ── */}
          {techPartners.length > 0 && (
            <div class="mb-16">
              <div class="text-center mb-10">
                <h2 class="text-2xl sm:text-3xl font-bold text-cdl-blue mb-3">Partenaires techniques</h2>
                <p class="text-cdl-gray max-w-2xl mx-auto">
                  Ils nous fournissent des services, du matériel ou de l'expertise pour faire vivre l'événement.
                </p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {techPartners.map((partner) => (
                  <a
                    href={partner.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-start gap-4 p-5 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-md transition-all"
                  >
                  
                    <img
                      src={partner.data.logo_light ?? partner.data.logo}
                      alt=""
                      class="h-12 w-12 object-contain flex-shrink-0 dark:hidden"
                      loading="lazy"
                    />
                    <img
                      src={partner.data.logo}
                      alt=""
                      class="h-12 w-12 object-contain flex-shrink-0 hidden dark:block"
                      loading="lazy"
                    />
                    <div>
                      <p class="font-bold text-cdl-blue text-sm">{partner.data.name}</p>
                      {partner.data.description && (
                        <p class="text-xs text-cdl-gray mt-1">{partner.data.description}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-20">
          <div class="inline-flex items-center justify-center h-16 w-16 rounded-full bg-cdl-orange/10 mb-6">
            <svg class="h-8 w-8 text-cdl-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-cdl-blue mb-4">Partenaires à venir</h2>
          <p class="text-cdl-gray max-w-md mx-auto">
            Les partenaires de l'édition {config.edition.year} seront annoncés prochainement.
          </p>
        </div>
      )}

      {/* Photos */}
      {sponsorPhotos.length > 0 && (
        <div class="mt-16">
          <h2 class="text-xl font-bold text-cdl-blue mb-4 text-center">En images</h2>
          <div class="lightbox-gallery grid grid-cols-2 md:grid-cols-4 gap-3 mb-12">
            {sponsorPhotos.slice(0, 4).map((photo) => (
              <div class="relative overflow-hidden rounded-xl">
                <Picture
                  src={photo.src}
                  alt={photo.alt}
                  class="w-full aspect-[4/3] object-cover"
                  sizes="(max-width: 768px) 50vw, 25vw"
                />
              </div>
            ))}
          </div>
        </div>
      )}

      {/* CTA devenir sponsor */}
      <div class="mt-16 bg-cdl-blue-fixed text-white rounded-2xl p-8 sm:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">Devenir sponsor</h2>
        <p class="text-white/80 mb-8 max-w-2xl mx-auto">
          Soutenez le logiciel libre et gagnez en visibilité auprès de {config.stats.visitors.toLocaleString('fr-FR')} passionnés.
          Consultez notre plaquette partenaires pour découvrir les différentes formules.
        </p>
        <a
          href="/static/pdf/Capitole-du-Libre-2026-Plaquette-Partenaires.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 text-lg font-medium text-cdl-blue-fixed bg-white hover:bg-white/90 rounded-xl transition-colors shadow-lg"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Télécharger la plaquette partenaires
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

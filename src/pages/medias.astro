---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import JsonLd from '../components/ui/JsonLd.astro';
import Picture from '../components/ui/Picture.astro';
import { config } from '../config';
import { breadcrumb } from '../lib/jsonld';
import { getPhotosByTag } from '../lib/photos';

const conferencePhotos = getPhotosByTag('conference');
const captationPhotos = getPhotosByTag('captation');
const ambiance = getPhotosByTag('ambiance');
---

<BaseLayout title="Médias" description="Vidéos des conférences, galerie photo et archives du Capitole du Libre.">
  <JsonLd slot="head" data={breadcrumb([{ name: 'Médias', path: '/medias' }])} />
  <PageHeader title="Médias" description="Retrouvez les conférences en vidéo et les photos de l'événement." />

  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      {/* Captation vidéo */}
      <div class="flex flex-col lg:flex-row gap-10 items-center mb-16">
        <div class="lg:w-1/2">
          <h2 class="text-2xl sm:text-3xl font-bold text-cdl-blue mb-4">
            Toutes les conférences en vidéo
          </h2>
          <p class="text-cdl-gray leading-relaxed mb-4">
            Chaque année, l'intégralité des conférences du Capitole du Libre est enregistrée
            par notre équipe vidéo bénévole. Les captations sont publiées dans les semaines
            qui suivent l'événement, en accès libre et gratuit.
          </p>
          <p class="text-cdl-gray leading-relaxed mb-6">
            Seules exceptions : les conférences dont le speaker a explicitement demandé
            la non-diffusion, ou en cas de problème technique.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={config.links.videos}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-white bg-cdl-orange hover:bg-cdl-orange-light rounded-lg transition-colors font-medium text-sm"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              PeerTube (instance libre)
            </a>
            <a
              href="https://www.youtube.com/@capitoledulibre"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-cdl-blue border border-cdl-gray-light hover:border-cdl-orange/30 rounded-lg transition-colors font-medium text-sm"
            >
              Chaîne YouTube
            </a>
          </div>
        </div>
        <div class="lg:w-1/2">
          {conferencePhotos[0] && (
            <Picture
              src={conferencePhotos[0].src}
              alt={conferencePhotos[0].alt}
              class="w-full aspect-[4/3] object-cover rounded-2xl shadow-lg"
              sizes="(max-width: 1024px) 100vw, 50vw"
            />
          )}
        </div>
      </div>

      {/* En coulisses : captation */}
      {captationPhotos.length > 0 && (
        <div class="mb-16">
          <h2 class="text-2xl sm:text-3xl font-bold text-cdl-blue mb-4 text-center">En coulisses</h2>
          <p class="text-cdl-gray text-center mb-8 max-w-2xl mx-auto">
            Derrière chaque vidéo, une équipe de bénévoles passionnés qui assure la captation, la régie et le son.
          </p>
          <div class="lightbox-gallery grid grid-cols-2 md:grid-cols-4 gap-3">
            {captationPhotos.slice(0, 4).map((photo) => (
              <div class="relative overflow-hidden rounded-xl">
                <Picture
                  src={photo.src}
                  alt={photo.alt}
                  class="w-full aspect-[4/3] object-cover"
                  sizes="(max-width: 768px) 50vw, 25vw"
                />
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Galerie photo */}
      <div class="mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-cdl-blue mb-4 text-center">Galerie photo</h2>
        <p class="text-cdl-gray text-center mb-8 max-w-2xl mx-auto">
          Retrouvez les photos des éditions précédentes sur notre galerie en ligne.
        </p>

        {/* Aperçu en grille */}
        <div class="lightbox-gallery grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
          {ambiance.slice(0, 8).map((photo) => (
            <div class="relative overflow-hidden rounded-xl group">
              <Picture
                src={photo.src}
                alt={photo.alt}
                class="w-full aspect-square object-cover transition-transform duration-500 group-hover:scale-105"
                sizes="(max-width: 768px) 50vw, 25vw"
              />
            </div>
          ))}
        </div>

        <div class="text-center">
          <a
            href={config.links.photos}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-cdl-orange hover:text-cdl-orange-light font-medium transition-colors"
          >
            Voir toutes les photos
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      {/* Témoignages vidéo */}
      <div class="text-center bg-white dark:bg-gray-900 rounded-2xl p-8 sm:p-12 border border-cdl-gray-light">
        <h2 class="text-2xl font-bold text-cdl-blue mb-4">Témoignages en vidéo</h2>
        <p class="text-cdl-gray mb-6 max-w-2xl mx-auto">
          Découvrez les interviews de speakers et participants qui partagent leur expérience du Capitole du Libre.
        </p>
        <a
          href="/temoignages"
          class="inline-flex items-center gap-2 px-6 py-3 text-white bg-cdl-orange hover:bg-cdl-orange-light rounded-lg transition-colors font-medium"
        >
          Voir les témoignages
        </a>
      </div>

      {/* Partenaires médias */}
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-cdl-blue mb-4 text-center">Nos partenaires médias</h2>
        <p class="text-cdl-gray text-center mb-8 max-w-2xl mx-auto">
          Les captations vidéo et les photos du Capitole du Libre sont réalisées en partenariat
          avec les clubs étudiants de l'ENSEEIHT.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
          <a
            href="https://tvn7.fr"
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center gap-3 p-6 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-md transition-all"
          >
            <img src="/static/img/partners/logo-tvn7.png" alt="TVn7" class="h-16 w-auto" loading="lazy" />
            <div class="text-center">
              <p class="font-bold text-cdl-blue text-sm">TVn7</p>
              <p class="text-xs text-cdl-gray">Captation vidéo</p>
            </div>
          </a>
          <a
            href="https://photo7.inpt.fr/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center gap-3 p-6 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-md transition-all"
          >
            <img src="/static/img/partners/logo-photo7.png" alt="Photo7" class="h-16 w-auto" loading="lazy" />
            <div class="text-center">
              <p class="font-bold text-cdl-blue text-sm">Photo7</p>
              <p class="text-xs text-cdl-gray">Photographie</p>
            </div>
          </a>
          <a
            href="https://can7.fr/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center gap-3 p-6 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-md transition-all"
          >
            <img src="/static/img/partners/logo-can7.png" alt="CAn7" class="h-16 w-auto" loading="lazy" />
            <div class="text-center">
              <p class="font-bold text-cdl-blue text-sm">CAn7</p>
              <p class="text-xs text-cdl-gray">Régie son et lumière</p>
            </div>
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

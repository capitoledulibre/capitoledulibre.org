---
import { config } from '../../config';
import ObfuscatedEmail from '../ui/ObfuscatedEmail.astro';
---

<footer class="bg-cdl-blue-dark-fixed text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- À propos -->
      <div>
        <img
          src="/static/img/logo-capitoledulibre.svg"
          alt="Capitole du Libre"
          class="h-12 w-auto mb-4 brightness-0 invert"
          width="48"
          height="48"
        />
        <p class="text-sm text-white/70 leading-relaxed">
          Le Capitole du Libre est un événement gratuit et ouvert à tous, organisé
          par l'association <a href={config.links.toulibre} class="underline hover:text-cdl-gold transition-colors">Toulibre</a>.
        </p>
      </div>

      <!-- Liens rapides -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-cdl-gold mb-4">Liens rapides</h3>
        <ul class="space-y-2 text-sm" role="list">
          <li><a href="/programme" class="text-white/70 hover:text-white transition-colors">Programme</a></li>
          <li><a href="/lieu" class="text-white/70 hover:text-white transition-colors">Lieu & accès</a></li>
          <li><a href="/village-associatif" class="text-white/70 hover:text-white transition-colors">Village associatif</a></li>
          <li><a href="/se-restaurer" class="text-white/70 hover:text-white transition-colors">Se restaurer</a></li>
          <li><a href="/devenir-speaker" class="text-white/70 hover:text-white transition-colors">Devenir speaker</a></li>
          <li><a href="/partenaires" class="text-white/70 hover:text-white transition-colors">Partenaires</a></li>
          <li><a href="/medias" class="text-white/70 hover:text-white transition-colors">Médias</a></li>
          <li><a href="/faq" class="text-white/70 hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/equipe" class="text-white/70 hover:text-white transition-colors">Équipe</a></li>
          <li><a href="/contact" class="text-white/70 hover:text-white transition-colors">Contact</a></li>
          <li><a href="/temoignages" class="text-white/70 hover:text-white transition-colors">Témoignages</a></li>
          <li><a href="/code-de-conduite" class="text-white/70 hover:text-white transition-colors">Code de conduite</a></li>
        </ul>
      </div>

      <!-- Contact & réseaux -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-cdl-gold mb-4">Suivez-nous</h3>
        <ul class="space-y-2 text-sm" role="list">
          <li>
            <a href={config.links.toulibre} class="text-white/70 hover:text-white transition-colors">
              Association Toulibre
            </a>
          </li>
          <li>
            <a href={config.links.videos} class="text-white/70 hover:text-white transition-colors">
              Vidéos des conférences
            </a>
          </li>
          <li>
            <a href={config.links.photos} class="text-white/70 hover:text-white transition-colors">
              Photos des éditions
            </a>
          </li>
          <li>
            <a href={config.social.matrix} class="text-white/70 hover:text-white transition-colors">
              Salon Matrix
            </a>
          </li>
          <li>
            <a href={config.social.discord} class="text-white/70 hover:text-white transition-colors">
              Discord
            </a>
          </li>
        </ul>

        <div class="flex flex-wrap items-center gap-3 mt-6">
          <a href={config.social.mastodon} rel="me noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="Mastodon">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.544c.568 0 1.133-.014 1.691-.049 2.284-.134 4.424-.732 4.69-.804a.166.166 0 0 0 .122-.146c.346-2.77.32-6.782.05-8.99Zm-3.844 8.36h-2.248v-5.59c0-1.18-.494-1.778-1.488-1.778-1.097 0-1.646.71-1.646 2.113v3.062h-2.234v-3.062c0-1.403-.549-2.113-1.647-2.113-.994 0-1.488.599-1.488 1.779v5.589H6.425V8.223c0-1.179.302-2.115.907-2.808.625-.693 1.443-1.048 2.46-1.048 1.176 0 2.066.452 2.649 1.354l.57.956.572-.956c.583-.902 1.473-1.354 2.648-1.354 1.017 0 1.836.355 2.46 1.048.606.693.908 1.63.908 2.808v5.45Z"/></svg>
          </a>
          <a href={config.social.bluesky} rel="noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="Bluesky">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.158 3.239-4.344.656-8.143 2.401-3.504 8.5 5.1 5.834 7.257-1.456 8.722-5.39.146-.393.22-.59.22-.43 0-.159.073.037.22.43 1.465 3.934 3.622 11.224 8.722 5.39 4.639-6.099.84-7.844-3.504-8.5 2.558.237 5.373-.612 6.158-3.239C24.062 9.418 24.44 4.458 24.44 3.768c0-.688-.139-1.86-.902-2.203-.66-.299-1.664-.621-4.3 1.24C16.486 4.748 13.527 8.687 12.44 10.8h-.88Z"/></svg>
          </a>
          <a href={config.social.twitter} rel="noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="X (Twitter)">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={config.social.linkedin} rel="noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={config.social.facebook} rel="noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={config.social.instagram} rel="noopener noreferrer" target="_blank" class="text-white/50 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
          </a>
          <ObfuscatedEmail label="" class="text-white/50 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </ObfuscatedEmail>
        </div>
      </div>
    </div>

    <!-- Autres éditions -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <p class="text-xs font-semibold uppercase tracking-wider text-cdl-gold mb-3">Autres éditions</p>
      <div class="flex flex-wrap gap-2">
        {config.pastEditions.map((edition) => (
          <a
            href={edition.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-white/50 hover:text-white px-2 py-1 rounded border border-white/10 hover:border-white/30 transition-colors"
          >
            {edition.year}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/50">
        &copy; {config.edition.year} Capitole du Libre — Organisé par
        <a href={config.links.toulibre} class="underline hover:text-white/70">Toulibre</a>
      </p>
      <p class="text-xs text-white/50">
        Contenu sous licence <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.fr" class="underline hover:text-white/70" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a>
      </p>
    </div>
  </div>
</footer>

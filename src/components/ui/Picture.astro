---
/**
 * Responsive <picture> component with AVIF > WebP > JPG fallback.
 * Expects optimized images generated by scripts/optimize-images.mjs
 * in the same directory as the source image.
 *
 * All photos are clickable to open in lightbox by default.
 * Set lightbox={false} to disable.
 *
 * Usage:
 *   <Picture src="/static/img/img01.jpg" alt="Description" />
 *   <Picture src="/static/img/img01.jpg" alt="Description" lightbox={false} />
 */
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  sizes?: string;
  widths?: number[];
  width?: number;
  height?: number;
  lightbox?: boolean;
}

const {
  src,
  alt,
  class: className,
  loading = 'lazy',
  fetchpriority,
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
  widths = [480, 960, 1440],
  width = 1440,
  height = 960,
  lightbox = true,
} = Astro.props;

// Derive base path and extension
const lastDot = src.lastIndexOf('.');
const basePath = src.substring(0, lastDot);
const ext = src.substring(lastDot);

function srcset(format: string): string {
  return widths
    .map((w) => `${basePath}-${w}w.${format} ${w}w`)
    .join(', ');
}
---

<picture
  class:list={[lightbox && 'lightbox-trigger cursor-pointer']}
  data-full={lightbox ? src : undefined}
  data-alt={lightbox ? alt : undefined}
>
  <source
    type="image/avif"
    srcset={srcset('avif')}
    sizes={sizes}
  />
  <source
    type="image/webp"
    srcset={srcset('webp')}
    sizes={sizes}
  />
  <img
    src={src}
    alt={alt}
    class={className}
    loading={loading}
    decoding={loading === 'lazy' ? 'async' : undefined}
    fetchpriority={fetchpriority}
    sizes={sizes}
    width={width}
    height={height}
  />
</picture>

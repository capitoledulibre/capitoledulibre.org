<section class="py-16 sm:py-24 bg-white dark:bg-gray-900 section-slant-both relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-cdl-blue mb-4">
        Ce qui vous attend
      </h2>
      <p class="text-lg text-cdl-gray">
        Un programme riche et varié pour découvrir toutes les facettes du logiciel libre.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {highlights.map((item) => (
        <div class="group p-6 rounded-xl border border-cdl-gray-light bg-white dark:bg-gray-800 hover:border-cdl-orange/30 hover:shadow-lg transition-all">
          <div class="inline-flex items-center justify-center h-12 w-12 rounded-xl bg-cdl-orange/10 mb-4 group-hover:bg-cdl-orange/20 transition-colors">
            <svg class="h-6 w-6 text-cdl-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={item.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-cdl-blue mb-2">{item.title}</h3>
          <p class="text-sm text-cdl-gray leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

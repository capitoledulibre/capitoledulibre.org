---
const testimonials = [
  {
    quote: 'Le Capitole du Libre est une des dernières grandes conférences Open Source de France et beaucoup de gens y viennent et on y retrouve une vraie communauté.',
    name: 'JB Kempf',
    role: 'Créateur de VLC',
  },
  {
    quote: 'C\'est pour moi un moment à ne pas rater dans l\'année, c\'est l\'occasion de croiser de nouvelles têtes, d\'en recroiser de connues, il y a un programme très riche, j\'adore le mélange de sérieux et d\'esprit bon enfant de l\'événement et la diversité des conférences.',
    name: 'Sébastien Dinot',
    role: 'Speaker — CS Group',
  },
];
---

<section class="py-16 sm:py-24 section-glow">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-cdl-blue mb-4">
        Ils en parlent mieux que nous
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {testimonials.map((t) => (
        <blockquote class="relative p-6 sm:p-8 rounded-2xl border border-cdl-gray-light bg-white dark:bg-gray-800">
          {/* Guillemet décoratif */}
          <svg class="absolute top-4 right-4 h-8 w-8 text-cdl-orange/10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          <p class="text-cdl-gray leading-relaxed mb-6 italic">
            "{t.quote}"
          </p>
          <footer class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-cdl-orange/10 flex items-center justify-center">
              <span class="text-sm font-bold text-cdl-orange">{t.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-sm font-medium text-cdl-blue">{t.name}</p>
              <p class="text-xs text-cdl-gray">{t.role}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/temoignages"
        class="inline-flex items-center gap-2 text-cdl-orange hover:text-cdl-orange-light font-medium transition-colors"
      >
        Voir les témoignages en vidéo
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </a>
    </div>
  </div>
</section>
